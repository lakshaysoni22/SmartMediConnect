# Copy to `.env.local` for local dev. In Vercel: Project → Settings → Environment Variables (same names).

# Supabase (see src/lib/supabaseClient.ts)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_PROJECT_REF=xxxx
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=

# Google Maps JavaScript API (browser key; must allow your domain)
VITE_GOOGLE_MAPS_API_KEY=

# Google AI Gemini (optional; health bot falls back if unset)
VITE_GEMINI_API_KEY=
